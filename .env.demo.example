# Vercel Environment Variables — Demo Branch
#
# Copy these into Vercel → Project Settings → Environment Variables
# for the `demo` branch deployment.
#
# ⚠️  Do NOT commit real secrets. Use Vercel's dashboard to set these.

# ─── Required ───────────────────────────────────────────────────────────────

# Enables hardcoded demo mode (no database needed)
NEXT_PUBLIC_DEMO_MODE=true

# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>

# The URL Vercel assigns to your deployment (set after first deploy)
NEXTAUTH_URL=https://<your-project>.vercel.app

# ─── Optional (leave blank in demo mode) ───────────────────────────────────

# Slack integration — not needed in demo mode
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=

# ─── What NEXT_PUBLIC_DEMO_MODE does ────────────────────────────────────────
# - Dashboard loads instantly with pre-built demo agents & task runs
# - Login page is bypassed (visitors land directly on the dashboard)
# - All write operations (create agent, create task) are disabled
# - No database connection is required
