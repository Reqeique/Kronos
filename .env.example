# Copy this file to `.env.local` and adjust as needed.
# It is loaded by Next.js automatically; nothing else reads it.

# --- Auth (required for next-auth; used to sign JWT session cookies) -------
# Generate one fresh per machine with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Without a stable value, dev sessions invalidate on every server restart
# and certain configuration paths warn on stderr.
NEXTAUTH_SECRET="kronos-dev-default-secret-authjs-32bytes-fallback"

# --- Bridge token (used by `kronos login` and CLI agent <-> server auth) ---
# Same secret can be used; rotate independently for stricter setups.
KRONOS_BRIDGE_TOKEN_SECRET="kronos-dev-bridge-secret"

# --- Public URL for next-auth callbacks -----------------------------------
NEXTAUTH_URL="http://localhost:3737"

# --- Optional: cron / shared scheduler flag tunables ----------------------
# Set `KRONOS_LOG_DIR=/tmp/kronos-logs` if you want server logs written to a
# file as well as stdout. Useful when stdout is detached or piped (e.g.
# background `kronos up`), because EPIPE on a closed FD will not then lose
# the warning.
# KRONOS_LOG_DIR=

# Set to `0` to opt out of the in-process scheduler at Next.js boot.
# Useful when running multiple replicas or a dedicated scheduler job.
# NEXT_RUNTIME_KRONOS_SCHEDULER=1
